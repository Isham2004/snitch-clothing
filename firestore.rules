rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Products & catalog metadata are publicly readable.
    // Authenticated users can WRITE only when the collection is empty
    // (first-time seeding). Once products exist, writes are locked down
    // unless the caller has role == 'admin' in their user document.
    match /products/{productId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /banners/{bannerId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User profile + subcollections (orders, favorites, addresses).
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /{collection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Carts per user.
    match /carts/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /items/{itemId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Top-level orders mirror (for admin visibility in Firestore console).
    // Each order doc has a `uid` field; only its owner can read/write it.
    match /orders/{orderId} {
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow read, update, delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }
  }
}
